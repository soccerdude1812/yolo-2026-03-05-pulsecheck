# PulseCheck — Environment Variables
# Copy this file to .env.local and fill in real values.
# All values are .trim()'d in src/lib/utils/env.ts — safe to paste from terminal.

# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE (uses legacy eyJ... JWT format — not the new publishable format)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...       # service_role key — NEVER expose client-side

# ─────────────────────────────────────────────────────────────────────────────
# GITHUB OAUTH
# Create at: https://github.com/settings/developers -> OAuth Apps
# Callback URL: http://localhost:3000/auth/callback (dev)
# ─────────────────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=Iv1.xxxx
GITHUB_CLIENT_SECRET=xxxx

# Personal access token for server-side GitHub API calls (raises rate limit to 5000/hr)
# Generate: https://github.com/settings/tokens (classic, read-only scopes)
GITHUB_TOKEN=ghp_xxxx

# ─────────────────────────────────────────────────────────────────────────────
# AI PROVIDERS
# ─────────────────────────────────────────────────────────────────────────────
# Gemini 2.0 Flash (primary) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# Groq Llama 3.3 70B (fallback) — https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# ─────────────────────────────────────────────────────────────────────────────
# CRON AUTHENTICATION
# Must be >= 32 characters of cryptographically random hex.
# Generate: openssl rand -hex 32
# Vercel cron sends: Authorization: Bearer <CRON_SECRET>
# ─────────────────────────────────────────────────────────────────────────────
CRON_SECRET=   # Run: openssl rand -hex 32

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL (Resend) — https://resend.com/api-keys
# ─────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=alerts@yourdomain.com

# ─────────────────────────────────────────────────────────────────────────────
# APP URL
# Development: http://localhost:3000
# Production: https://your-vercel-domain.vercel.app
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
