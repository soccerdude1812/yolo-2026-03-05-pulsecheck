# PulseCheck — Environment Variables
# Copy to .env.local and fill in values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini
GEMINI_API_KEY=

# Groq (fallback)
GROQ_API_KEY=

# Resend (email alerts)
RESEND_API_KEY=

# Cron security
CRON_SECRET=   # Run: openssl rand -hex 32
